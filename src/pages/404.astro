---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="404 | Lost in the Infrastructure"
  description="Strona nie istnieje. Powrót do pulpitu głównego."
>
  <main class="min-h-screen bg-[#10141a] flex items-center justify-center py-12 px-6">
    <div class="max-w-lg w-full bg-[#1c2026] border border-[#3b494b]/30 p-10 md:p-14 rounded-xl shadow-2xl text-center space-y-8">
      
      <div class="relative inline-block">
        <span class="text-[80px] md:text-[100px] block font-mono text-[#00f0ff]">404</span>
        <div class="absolute -top-2 -right-2 w-4 h-4 bg-[#00f0ff] animate-pulse"></div>
      </div>

      <div class="space-y-4">
        <h1 class="font-bold text-[28px] md:text-[32px] text-white leading-tight font-sans">
          Connection <span class="text-[#00f0ff]">Lost...</span>
        </h1>
        <p class="text-[16px] text-[#b9cacb] leading-relaxed">
          The requested endpoint does not exist in the current infrastructure.
        </p>
        <p class="text-[14px] text-[#849495] font-mono pt-4" id="countdown-text">
          Reconnecting to root in <span id="countdown" class="font-bold text-[#00f0ff]">5</span>s...
        </p>
      </div>

      <div class="pt-4 flex flex-col gap-4">
        <a href="/" class="bg-[#00f0ff] text-[#00363a] font-bold px-8 py-3 rounded hover:scale-[1.02] active:scale-[0.98] transition-all text-[15px] block shadow-[0_0_15px_rgba(0,240,255,0.3)]">
          RETURN TO ROOT
        </a>
        <a href="/#contact" class="text-[#849495] hover:text-[#00f0ff] transition-colors text-[13px] font-mono border-b border-transparent hover:border-[#00f0ff] inline-block">
          REPORT SYSTEM ANOMALY
        </a>
      </div>

    </div>
  </main>
</Layout>

<script>
  let secondsLeft = 5;
  const countdownElement = document.getElementById('countdown');

  if (countdownElement) {
    const interval = setInterval(() => {
      secondsLeft--;
      countdownElement.textContent = String(secondsLeft);
      
      if (secondsLeft <= 0) {
        clearInterval(interval);
        window.location.href = '/';
      }
    }, 1000);
  }
</script>