---
interface Props {
  role: string;
  company: string;
  period: string;
  description: string;
  bullets: string[];
  tech: string[];
}

const { role, company, period, description, bullets, tech } = Astro.props;
---
<div class="relative pl-8 pb-12 last:pb-0 group">
  <div class="absolute left-0 top-1.5 bottom-0 w-[2px] bg-gradient-to-b from-[#00f0ff] to-[#3b494b]/20 group-last:bottom-auto group-last:h-4"></div>
  <div class="absolute left-[-5px] top-1.5 w-3 h-3 bg-[#10141a] border-2 border-[#00f0ff] rounded-full group-hover:bg-[#00f0ff] transition-colors duration-300 shadow-[0_0_10px_rgba(0,240,255,0.5)]"></div>

  <div class="space-y-3">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1">
      <h3 class="text-[20px] font-bold text-[#dbfcff] font-sans">
        {role} <span class="text-[#00f0ff] font-normal">@ {company}</span>
      </h3>
      <span class="text-[12px] font-mono text-[#849495] bg-[#1c2026] border border-[#3b494b]/30 px-2.5 py-0.5 rounded sm:self-start">
        {period}
      </span>
    </div>

    <p class="text-[15px] text-[#b9cacb] font-sans leading-relaxed max-w-3xl">
      {description}
    </p>

    <ul class="space-y-2 text-[14px] text-[#dfe2eb] pl-1">
      {bullets.map((bullet) => (
        <li class="flex items-start gap-2.5">
          <span class="w-1.5 h-1.5 bg-[#00f0ff]/60 rounded-full mt-2 shrink-0"></span>
          <span>{bullet}</span>
        </li>
      ))}
    </ul>

    <div class="flex flex-wrap gap-2 pt-2 font-mono text-[11px]">
      {tech.map((t) => (
        <span class="text-[#a5e7ff] opacity-80">#{t}</span>
      ))}
    </div>
  </div>
</div>