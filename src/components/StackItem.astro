---
interface Props {
  icon: string;
  label: string;
}

const { icon, label } = Astro.props;
---
<div class="flex flex-col items-center gap-2 group text-center font-mono text-[14px]">
  <div class="w-12 h-12 flex items-center justify-center bg-[rgba(22,27,34,0.7)] backdrop-blur-xl border border-[rgba(219,252,255,0.1)] rounded group-hover:border-[#dbfcff]/50 transition-all">
    <span class="material-symbols-outlined text-[#a5e7ff]">{icon}</span>
  </div>
  <span>{label}</span>
</div>